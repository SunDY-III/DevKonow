# DevKnow 开发环境配置
# 复制为 .env.dev 后与 docker-compose 一起使用：
#   docker compose --env-file .env.dev up
#
# 相比 .env.example（生产默认），本配置降低资源限制约 50%，
# 适合本地开发运行。

# ==================== 数据库 ====================
DB_PASSWORD=devpass123

# ==================== Redis ====================
REDIS_PASSWORD=devpass456

# ==================== 消息队列 ====================
RABBITMQ_USER=devknow
RABBITMQ_PASSWORD=devpass789

# ==================== 对象存储 ====================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=devpass000

# ==================== JWT ====================
JWT_SECRET=dev-secret-do-not-use-in-production
JWT_EXPIRE_HOURS=72

# ==================== LLM ====================
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_CHAT_MODEL=gpt-4o-mini

# ==================== Embedding ====================
EMBEDDING_MODEL=text-embedding-3-small

# ==================== Qdrant ====================
QDRANT_HOST=qdrant
QDRANT_PORT=6334
QDRANT_COLLECTION=devknow_vectors

# ==================== Docker 资源限制（开发环境低配版） ====================
BACKEND_MEM=1.5g
MYSQL_MEM=512m
QDRANT_MEM=512m
RABBITMQ_MEM=256m
MINIO_MEM=256m
REDIS_MEM=128m
