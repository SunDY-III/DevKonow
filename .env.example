# DevKnow 生产环境配置
# 复制此文件为 .env 并修改其中的密码

# ==================== 数据库 ====================
DB_PASSWORD=YourStrongDBPassword123

# ==================== Redis ====================
REDIS_PASSWORD=YourStrongRedisPass456

# ==================== 消息队列 ====================
RABBITMQ_USER=devknow
RABBITMQ_PASSWORD=YourStrongRabbitPass789

# ==================== 对象存储 ====================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=YourStrongMinioPass000

# ==================== JWT 认证（生产环境请用强随机字符串） ====================
# 生成方法：openssl rand -base64 32
JWT_SECRET=generate-with-openssl-rand-base64-32
JWT_EXPIRE_HOURS=72

# ==================== LLM 模型（OpenAI 协议兼容） ====================
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_CHAT_MODEL=gpt-4o-mini

# 轻量模型 = 分类/摘要/路由判题等非生成任务
# 推荐：DeepSeek V4 Flash（$0.10/$0.20）、GPT-4o mini（$0.15/$0.60）、Claude Haiku 4.5（$1.00/$5.00）
# 不配置则默认与 LLM_CHAT_MODEL 相同
# 当前使用 DeepSeek，推荐：
LLM_FAST_BASE_URL=${LLM_BASE_URL}
LLM_FAST_API_KEY=${LLM_API_KEY}
LLM_FAST_CHAT_MODEL=deepseek-v4-flash

# ==================== Embedding ====================
EMBEDDING_MODEL=text-embedding-3-small

# ==================== JVM 配置 ====================
# GC 选择：G1GC（默认）/ ZGC（实验，SSE 流式场景）
# JAVA_GC=ZGC
# JAVA_MAX_HEAP=2g

# ==================== Docker 资源限制（可选，默认开发配置） ====================
# 生产环境需提高限制：
#   BACKEND_MEM=4g  MYSQL_MEM=1g  QDRANT_MEM=1g
#   RABBITMQ_MEM=512m  MINIO_MEM=512m
# 完整生产配置见 .env.prod.example

# ==================== Qdrant ====================
QDRANT_HOST=qdrant
QDRANT_PORT=6334
QDRANT_COLLECTION=devknow_vectors
